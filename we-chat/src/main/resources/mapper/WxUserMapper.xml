<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.we.chat.mapper.WxUserMapper">
    <select id="selectByOpenid" resultType="com.we.chat.entity.WxUser">
        select * from wx_user where openid = #{openId}
    </select>

    <update id="updateUser">
        update wx_user
        set nickname=#{nickname},avatar=#{avatar},token=#{token},update_time=now()
        where openid=#{openid}
    </update>
</mapper>